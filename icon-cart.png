<!--/#mainWrap-->
</div>
<script language="JavaScript" type="text/javascript">
var dateObj    = new Date();
dateObj.setFullYear(dateObj.getFullYear() + 1);
var cookieDobj = new hmsCookie('r_login_dxlive_performer',dateObj.toUTCString());
cookieDobj.get();
if (cookieDobj.args.u) {
  document.login_form.FORM_USER.value = cookieDobj.args.u;
  document.login_form.remember_login.checked = true;
}

function remember_me() {
 if ( document.login_form.remember_login.checked ) {
   var dateObj    = new Date();
   dateObj.setFullYear(dateObj.getFullYear() + 1);
   var cookieDobj = new hmsCookie('r_login_dxlive_performer',dateObj.toUTCString());
   cookieDobj.add('u',document.login_form.FORM_USER.value);
   cookieDobj.set();
 } else {
   var dateObj    = new Date();
   dateObj.setFullYear(dateObj.getFullYear() - 1);
   var cobj= new hmsCookie('r_login_dxlive_performer',dateObj.toUTCString());
   cobj.add('u','');
   cobj.set();
 }
}
</script>
